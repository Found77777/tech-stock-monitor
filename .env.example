APP_NAME=A-Share Tech Stock Monitor
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///data/tech_monitor.db
DATA_SOURCE_PROVIDER=mock
TUSHARE_TOKEN=
SCHEDULER_TIMEZONE=Asia/Shanghai
MIN_AMOUNT=50000000

USE_MOCK_DATA=false
REAL_DATA_SOURCE=sina
# options: sina | akshare | mock | pytdx

# --- AI Agent ---
LLM_API_KEY=sk-your-openai-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_HTTP_PROXY=http://127.0.0.1:7890
AGENT_NEWS_SOURCES=sina,eastmoney,xueqiu
AGENT_ENABLED=false

ENABLE_FACTOR_REDUNDANCY_ADJUSTMENT=false

CAPITAL_FLOW_RETRY=3
CAPITAL_FLOW_SLEEP_MIN=10.0
CAPITAL_FLOW_SLEEP_MAX=20.0
